# ---------------------------------------------------------------------------
# Mohamed Hamdoun — portfolio environment
# Copy to `.env.local` for development. NEVER commit real secrets.
# Only the variables for your SELECTED EMAIL_PROVIDER are required.
# ---------------------------------------------------------------------------

# Public site origin — used for metadata, canonical URLs, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Contact email ---------------------------------------------------------
# EMAIL_PROVIDER: dev | resend | smtp
#   dev    -> no email sent; logs safe metadata + writes to ./.dev-inbox (default)
#   resend -> sends via Resend REST API (set RESEND_API_KEY)
#   smtp   -> sends via SMTP (requires nodemailer + SMTP_* — see lib/contact/provider.ts)
EMAIL_PROVIDER=dev

CONTACT_TO_EMAIL=mohamed2hamdoun@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Resend (only when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP (only when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Rate limiting ---------------------------------------------------------
# In-memory by default (per server instance). For serverless production, back
# this with Upstash/KV — see lib/contact/rate-limit.ts.
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW=600
